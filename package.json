{
  "name": "ovis-manager-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:installers": "scripts/build-installers.sh",
    "build:installers:macos": "scripts/build-macos-installers.sh",
    "generate:models-api": "openapi-typescript .debug/ovis-manager/openapi-models.yaml -o src/features/models/model.openapi.ts",
    "build": "node scripts/verify-managed-policy.mjs && node scripts/verify-installers.mjs && tsc --noEmit -p tsconfig.app.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:installers": "scripts/test-linux-installers.sh && node scripts/verify-installers.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "i18next": "^26.3.6",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.9",
    "react-icons": "^5.7.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  }
}
